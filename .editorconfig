# EditorConfig for Go codebase
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.go]
indent_style = tab
indent_size = 4

# Go uses tabs by convention - gofmt standard
# Run: go fmt ./... to format all Go files

[*.md]
indent_style = space
indent_size = 2

[*.{json,yaml,yml}]
indent_style = space
indent_size = 2

[Dockerfile]
indent_style = space
indent_size = 4